{%- set rclonetype = mount.rclonetype if mount.rclonetype is defined and mount.rclonetype | length > 0 else 's3' %}
[remote]
{%- if rclonetype == 'sftp' %}
{%- set parts = mount.server.rsplit(':', 1) %}
type = sftp
host = {{ parts[0] }}
{%- if parts | length > 1 %}
port = {{ parts[1] }}
{%- endif %}
user = {{ mount.username }}
pass = {{ mount.password }}
{%- elif rclonetype == 'ftp' %}
{%- set parts = mount.server.rsplit(':', 1) %}
type = ftp
host = {{ parts[0] }}
{%- if parts | length > 1 %}
port = {{ parts[1] }}
{%- endif %}
user = {{ mount.username }}
pass = {{ mount.password }}
{%- elif rclonetype == 'webdav' %}
type = webdav
url = {{ mount.server }}
vendor = other
user = {{ mount.username }}
pass = {{ mount.password }}
{%- elif rclonetype in ['drive', 'onedrive'] %}
# OAuth remote — configured via: rclone config
# Remote name: {{ mount.server }}
# This file is not used; the service unit references the pre-configured remote directly.
{%- else %}
{# default: s3 #}
type = s3
{%- if mount.server | length > 0 %}
provider = Other
endpoint = {{ mount.server }}
{%- else %}
provider = AWS
{%- endif %}
access_key_id = {{ mount.username }}
secret_access_key = {{ mount.password }}
{%- endif %}
