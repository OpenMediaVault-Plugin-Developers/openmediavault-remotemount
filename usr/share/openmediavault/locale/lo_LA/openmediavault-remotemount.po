msgid "Advanced"
msgstr "ຂັ້ນສູງ"

msgid "Amazon S3 / S3-Compatible"
msgstr "Amazon S3 / ຮອງຮັບ S3"

msgid "Connection"
msgstr "ການເຊື່ອມຕໍ່"

msgid "Create"
msgstr "ສ້າງ"

msgid "Created mount."
msgstr "ສ້າງຈຸດເຊື່ອມຕໍ່ແລ້ວ."

msgid "Credentials"
msgstr "ຂໍ້ມູນປະຈຳຕົວ"

msgid "Edit"
msgstr "ແກ້ໄຂ"

msgid "Edit mount."
msgstr "ແກ້ໄຂຈຸດເຊື່ອມຕໍ່."

msgid "Enable to use NFSv4, disable for NFSv3."
msgstr "ເປີດນຳໃຊ້ສຳລັບ NFSv4, ປິດສຳລັບ NFSv3."

msgid "FTP"
msgstr "FTP"

msgid "Google Drive (pre-configured rclone remote)"
msgstr "Google Drive (ຕັ້ງຄ່າ rclone ໄລຍະໄກໄວ້ລ່ວງໜ້າ)"

msgid "Mount"
msgstr "ເຊື່ອມຕໍ່"

msgid "Mount type"
msgstr "ປະເພດການເຊື່ອມຕໍ່"

msgid "Mounted"
msgstr "ເຊື່ອມຕໍ່ແລ້ວ"

msgid "NFS"
msgstr "NFS"

msgid "NFS v4"
msgstr "NFS v4"

msgid "Name"
msgstr "ຊື່"

msgid "OneDrive (pre-configured rclone remote)"
msgstr "OneDrive (ຕັ້ງຄ່າ rclone ໄລຍະໄກໄວ້ລ່ວງໜ້າ)"

msgid "Options"
msgstr "ຕົວເລືອກ"

msgid "Password"
msgstr "ລະຫັດຜ່ານ"

msgid "Protocol"
msgstr "ໂປຣໂຕຄໍ"

msgid "Remote Mount"
msgstr "ການເຊື່ອມຕໍ່ໄລຍະໄກ"

msgid "Remote Mounts"
msgstr "ການເຊື່ອມຕໍ່ໄລຍະໄກ"

msgid "SFTP"
msgstr "SFTP"

msgid "SMB/CIFS"
msgstr "SMB/CIFS"

msgid ""
"SMB/CIFS or NFS — hostname or IP.<br/>WebDAV (davfs) — full URL (e.g. "
"https://example.com/dav).<br/>S3 — endpoint URL (blank for "
"AWS).<br/>SFTP/FTP — hostname[:port].<br/>Google Drive/OneDrive — name of a "
"pre-configured rclone remote (run rclone config first)."
msgstr ""
"SMB/CIFS ຫຼື NFS — ຊື່ໂຮສ ຫຼື IP.<br/>WebDAV (davfs) — URL ເຕັມ (ຕົວຢ່າງ "
"https://example.com/dav).<br/>S3 — URL ເອັນພອຍ (ຫວ່າງໄວ້ສຳລັບ "
"AWS).<br/>SFTP/FTP — ຊື່ໂຮສ[:ພອດ].<br/>Google Drive/OneDrive — ຊື່ຂອງ rclone"
" ໄລຍະໄກທີ່ຕັ້ງຄ່າໄວ້ລ່ວງໜ້າ (ຕ້ອງແລ່ນ rclone config ກ່ອນ)."

msgid ""
"SMB/CIFS or WebDAV — password (leave blank for guest)<br>S3 — secret access "
"key<br/>SFTP/FTP — password (auto-obscured on save)."
msgstr ""
"SMB/CIFS ຫຼື WebDAV — ລະຫັດຜ່ານ (ຫວ່າງໄວ້ສຳລັບບຸກຄົນທົ່ວໄປ)<br>S3 — "
"ຄີເຂົ້າເຖິງລັບ<br/>SFTP/FTP — ລະຫັດຜ່ານ (ຈະຖືກປິດບັງອັດຕະໂນມັດເມື່ອບັນທຶກ)."

msgid ""
"SMB/CIFS or WebDAV — username (leave blank for guest)<br/>S3 — access key "
"ID<br/>SFTP/FTP — username."
msgstr ""
"SMB/CIFS ຫຼື WebDAV — ຊື່ຜູ້ໃຊ້ (ຫວ່າງໄວ້ສຳລັບບຸກຄົນທົ່ວໄປ)<br/>S3 — "
"ໄອດີຄີເຂົ້າເຖິງ<br/>SFTP/FTP — ຊື່ຜູ້ໃຊ້."

msgid ""
"SMB/CIFS see <a href='https://linux.die.net/man/8/mount.cifs' "
"target='_blank'>mount.cifs</a><br/>NFS see <a "
"href='https://linux.die.net/man/8/mount.nfs' "
"target='_blank'>mount.nfs</a><br/>WebDAV see <a "
"href='https://linux.die.net/man/8/mount.davfs' "
"target='_blank'>mount.davfs</a><br/>rclone — extra mount flags (e.g. --vfs-"
"cache-mode=writes)."
msgstr ""
"SMB/CIFS ເບິ່ງ <a href='https://linux.die.net/man/8/mount.cifs' "
"target='_blank'>mount.cifs</a><br/>NFS ເບິ່ງ <a "
"href='https://linux.die.net/man/8/mount.nfs' "
"target='_blank'>mount.nfs</a><br/>WebDAV ເບິ່ງ <a "
"href='https://linux.die.net/man/8/mount.davfs' "
"target='_blank'>mount.davfs</a><br/>rclone — ແຟລັກການເຊື່ອມຕໍ່ເພີ່ມເຕີມ "
"(ຕົວຢ່າງ --vfs-cache-mode=writes)."

msgid ""
"SMB/CIFS — share name<br/>NFS — export path<br/>S3 — bucket "
"name<br/>SFTP/FTP — remote directory path<br/>WebDAV — subdirectory "
"(optional)<br/>Drive/OneDrive — folder path (optional)"
msgstr ""
"SMB/CIFS — ຊື່ແຊຣ໌<br/>NFS — ເສັ້ນທາງເອັກສະປອດ<br/>S3 — "
"ຊື່ບັກເກັດ<br/>SFTP/FTP — ເສັ້ນທາງໄດເຣັກທໍຣີໄລຍະໄກ<br/>WebDAV — ໂຟນເດີຍ່ອຍ "
"(ເລືອກໄດ້)<br/>Drive/OneDrive — ເສັ້ນທາງໂຟນເດີ (ເລືອກໄດ້)"

msgid "Server"
msgstr "ເຊີເວີ"

msgid "Share"
msgstr "ແຊຣ໌"

msgid "Share / Path"
msgstr "ແຊຣ໌ / ເສັ້ນທາງ"

msgid "Shared"
msgstr "ແບ່ງປັນແລ້ວ"

msgid "Type"
msgstr "ປະເພດ"

msgid "Unmount"
msgstr "ຍົກເລີກການເຊື່ອມຕໍ່"

msgid "Username"
msgstr "ຊື່ຜູ້ໃຊ້"

msgid "WebDAV"
msgstr "WebDAV"

msgid "WebDAV (davfs)"
msgstr "WebDAV (davfs)"

msgid "rclone"
msgstr "rclone"
