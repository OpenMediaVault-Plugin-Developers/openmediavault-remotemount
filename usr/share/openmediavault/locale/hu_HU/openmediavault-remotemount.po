msgid "SMB/CIFS"
msgstr "SMB/CIFS"

msgid ""
"SMB/CIFS or NFS — hostname or IP.<br/>WebDAV (davfs) — full URL (e.g. "
"https://example.com/dav).<br/>S3 — endpoint URL (blank for "
"AWS).<br/>SFTP/FTP — hostname[:port].<br/>Google Drive/OneDrive — name of a "
"pre-configured rclone remote (run rclone config first)."
msgstr ""
"SMB/CIFS vagy NFS – gazdagépnév vagy IP-cím.<br/>WebDAV (davfs) – teljes "
"URL-cím (pl. https://pelda.hu/dav).<br/>S3 – végpont URL-cím (AWS esetén "
"hagyja üresen).<br/>SFTP/FTP – gazdagépnév[:port].<br/>Google Drive/OneDrive"
" – egy előre konfigurált rclone távoli eszköz neve (először futtassa az "
"rclone config parancsot)."

msgid ""
"SMB/CIFS or WebDAV — password (leave blank for guest)<br>S3 — secret access "
"key<br/>SFTP/FTP — password (auto-obscured on save)."
msgstr ""
"SMB/CIFS vagy WebDAV – jelszó (vendégként hagyja üresen)<br>S3 – titkos "
"hozzáférési kulcs<br/>SFTP/FTP – jelszó (mentéskor automatikusan elrejtésre "
"kerül)."

msgid ""
"SMB/CIFS or WebDAV — username (leave blank for guest)<br/>S3 — access key "
"ID<br/>SFTP/FTP — username."
msgstr ""
"SMB/CIFS vagy WebDAV – felhasználónév (vendégként hagyja üresen)<br/>S3 – "
"hozzáférési kulcs azonosítója<br/>SFTP/FTP – felhasználónév."

msgid ""
"SMB/CIFS see <a href='https://linux.die.net/man/8/mount.cifs' "
"target='_blank'>mount.cifs</a><br/>NFS see <a "
"href='https://linux.die.net/man/8/mount.nfs' "
"target='_blank'>mount.nfs</a><br/>WebDAV see <a "
"href='https://linux.die.net/man/8/mount.davfs' "
"target='_blank'>mount.davfs</a><br/>rclone — extra mount flags (e.g. --vfs-"
"cache-mode=writes)."
msgstr ""
"SMB/CIFS: lásd <a href='https://linux.die.net/man/8/mount.cifs' "
"target='_blank'>mount.cifs</a> <br/>NFS: lásd <a "
"href='https://linux.die.net/man/8/mount.nfs' target='_blank'>mount.nfs</a> "
"<br/>WebDAV: lásd <a href='https://linux.die.net/man/8/mount.davfs' "
"target='_blank'>mount.davfs</a> <br/>rclone – további csatlakoztatási opciók"
" (pl. --vfs-cache-mode=writes)."

msgid ""
"SMB/CIFS — share name<br/>NFS — export path<br/>S3 — bucket "
"name<br/>SFTP/FTP — remote directory path<br/>WebDAV — subdirectory "
"(optional)<br/>Drive/OneDrive — folder path (optional)"
msgstr ""
"SMB/CIFS – megosztás neve<br/>NFS – exportálási útvonal<br/>S3 – tároló "
"neve<br/>SFTP/FTP – távoli mappa útvonal<br/>WebDAV –almappa "
"(opcionális)<br/>Drive/OneDrive — mappa útvonal (opcionális)"

