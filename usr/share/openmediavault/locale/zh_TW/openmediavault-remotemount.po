msgid "SFTP"
msgstr "SFTP"

msgid "SMB/CIFS"
msgstr "SMB/CIFS"

msgid ""
"SMB/CIFS or NFS — hostname or IP.<br/>WebDAV (davfs) — full URL (e.g. "
"https://example.com/dav).<br/>S3 — endpoint URL (blank for "
"AWS).<br/>SFTP/FTP — hostname[:port].<br/>Google Drive/OneDrive — name of a "
"pre-configured rclone remote (run rclone config first)."
msgstr ""
"SMB/CIFS 或 NFS — 主機名稱 或 IP。<br/>WebDAV (davfs) — 完整 URL "
"(例如：https://example.com/dav)。<br/>S3 — 端點 URL (AWS 則留空白).<br/>SFTP/FTP — "
"主機名稱[:通訊埠]。<br/>Google Drive/OneDrive — 預先設置好的 rclone 遠端 (先執行 rclone "
"config)。"

msgid ""
"SMB/CIFS or WebDAV — password (leave blank for guest)<br>S3 — secret access "
"key<br/>SFTP/FTP — password (auto-obscured on save)."
msgstr ""
"SMB/CIFS 或 WebDAV — 密碼 (給訪客則留空白)<br>S3 — 祕密存取金鑰<br/>SFTP/FTP — 密碼 "
"(儲存後會自動遮蔽)。"

msgid ""
"SMB/CIFS or WebDAV — username (leave blank for guest)<br/>S3 — access key "
"ID<br/>SFTP/FTP — username."
msgstr ""
"SMB/CIFS 或 WebDAV — 用戶名稱 (給訪客則留空白)<br/>S3 — 存取金鑰 ID<br/>SFTP/FTP — 用戶名稱。"

msgid ""
"SMB/CIFS see <a href='https://linux.die.net/man/8/mount.cifs' "
"target='_blank'>mount.cifs</a><br/>NFS see <a "
"href='https://linux.die.net/man/8/mount.nfs' "
"target='_blank'>mount.nfs</a><br/>WebDAV see <a "
"href='https://linux.die.net/man/8/mount.davfs' "
"target='_blank'>mount.davfs</a><br/>rclone — extra mount flags (e.g. --vfs-"
"cache-mode=writes)."
msgstr ""
"SMB/CIFS 參見 <a href='https://linux.die.net/man/8/mount.cifs' "
"target='_blank'>mount.cifs</a><br/>NFS 參見 <a "
"href='https://linux.die.net/man/8/mount.nfs' "
"target='_blank'>mount.nfs</a><br/>WebDAV 參見 <a "
"href='https://linux.die.net/man/8/mount.davfs' "
"target='_blank'>mount.davfs</a><br/>rclone — 額外載入旗標 (例如： --vfs-cache-"
"mode=writes)。"

msgid ""
"SMB/CIFS — share name<br/>NFS — export path<br/>S3 — bucket "
"name<br/>SFTP/FTP — remote directory path<br/>WebDAV — subdirectory "
"(optional)<br/>Drive/OneDrive — folder path (optional)"
msgstr ""
"SMB/CIFS — 分享名稱<br/>NFS — 匯出路徑<br/>S3 — bucket name<br/>SFTP/FTP — "
"遠端目錄路徑<br/>WebDAV — 子目錄 (選用性)<br/>Drive/OneDrive — 檔案夾路徑 (選用性)"

msgid "Server"
msgstr "伺服器"

